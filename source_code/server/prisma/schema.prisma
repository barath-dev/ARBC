generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// ─── ENUMS ───────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════

enum Role {
  RECRUITER
  STUDENT
  INSTITUTION // TPO / placement officer
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ClaimType {
  INTERNSHIP
  PROJECT
  SKILL
  CERTIFICATE
  EDUCATION
}

enum FlagSeverity {
  INFO
  WARNING
  CRITICAL
}

enum SkillStatus {
  VERIFIED
  PARTIAL
  UNVERIFIED
}

enum DocumentType {
  OFFER_LETTER
  CERTIFICATE
  TRANSCRIPT
  RECOMMENDATION
  OTHER
}

// ─── Placement Portal Enums ───────────────────────────────

enum JobVisibility {
  PUBLIC
  INSTITUTION_SPECIFIC
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum BoardEntryStatus {
  PENDING_INSTITUTION // company pushed — awaiting institution approval
  APPROVED
  REJECTED
  WITHDRAWN
}

enum BoardEntryInitiator {
  COMPANY
  INSTITUTION
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
  OFFERED
  WITHDRAWN
}

// ═══════════════════════════════════════════════════════════
// ─── CORE AUTH ────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student              Student?
  verificationsCreated VerificationRequest[] @relation("CreatedBy")
  auditLogs            AuditLog[]
  institutionMember    InstitutionMember?
  companyMember        CompanyMember?
  notifications        Notification[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════════
// ─── STUDENT ──────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════

model Student {
  id                String    @id @default(cuid())
  userId            String    @unique
  githubUsername    String?
  githubAccessToken String?   // Stored encrypted OAuth token for GitHub API
  linkedinUrl       String?
  resumeUrl         String?
  consentGiven      Boolean   @default(false)
  consentDate       DateTime?
  institutionId     String?   // bound institution
  inviteCodeId      String?   @unique // invite code used during onboarding
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution          Institution?          @relation("InstitutionStudents", fields: [institutionId], references: [id])
  inviteCode           InviteCode?           @relation("UsedInviteCode")
  claims               ResumeClaim[]
  verificationRequests VerificationRequest[]
  applications         Application[]

  @@map("students")
}

// ═══════════════════════════════════════════════════════════
// ─── RESUME CLAIMS ────────────────────────────────────────
// ═══════════════════════════════════════════════════════════

model ResumeClaim {
  id          String    @id @default(cuid())
  studentId   String
  type        ClaimType
  title       String
  company     String?
  repoUrl     String?   // GitHub repo URL for PROJECT/INTERNSHIP claims
  description String?
  skills      String[]
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  inconsistencyFlags InconsistencyFlag[]
  skillVerifications SkillVerification[]
  applicationClaims  ApplicationClaim[]

  @@map("resume_claims")
}

// ═══════════════════════════════════════════════════════════
// ─── VERIFICATION PIPELINE ────────────────────────────────
// ═══════════════════════════════════════════════════════════

model VerificationRequest {
  id            String             @id @default(cuid())
  studentId     String
  createdById   String
  applicationId String?            // null = recruiter-triggered; set = application-scoped ARBC
  status        VerificationStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  student             Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy           User                 @relation("CreatedBy", fields: [createdById], references: [id])
  githubAnalysis      GitHubAnalysis?
  companyVerification CompanyVerification?
  documentAnalyses    DocumentAnalysis[]
  result              VerificationResult?
  auditLogs           AuditLog[]

  @@map("verification_requests")
}

model GitHubAnalysis {
  id                    String    @id @default(cuid())
  verificationRequestId String    @unique
  username              String
  totalRepos            Int       @default(0)
  totalCommits          Int       @default(0)
  forkedRepos           Int       @default(0)
  originalRepos         Int       @default(0)
  languages             Json
  contributionScore     Float     @default(0)
  accountCreatedAt      DateTime?
  /// rG from Algorithm 2 (0.0 = legit, 1.0 = high fraud risk)
  githubRisk            Float     @default(0)
  rFork                 Float     @default(0)
  rPattern              Float     @default(0)
  rComplexity           Float     @default(0)
  rawData               Json?
  analyzedAt            DateTime  @default(now())

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)
  repositories        Repository[]

  @@map("github_analyses")
}

model Repository {
  id               String    @id @default(cuid())
  githubAnalysisId String
  name             String
  url              String
  isFork           Boolean   @default(false)
  stars            Int       @default(0)
  language         String?
  languages        Json?
  commitCount      Int       @default(0)
  firstCommitAt    DateTime?
  lastCommitAt     DateTime?
  description      String?
  /// Per-repo risk contribution (0.0 legit to 1.0 suspicious)
  repoRisk         Float     @default(0)

  githubAnalysis GitHubAnalysis @relation(fields: [githubAnalysisId], references: [id], onDelete: Cascade)

  @@map("repositories")
}

model CompanyVerification {
  id                    String    @id @default(cuid())
  verificationRequestId String    @unique
  companyName           String
  contactEmail          String?
  claimedRole           String?
  claimedStartDate      DateTime?
  claimedEndDate        DateTime?
  verified              Boolean?
  responseReceived      Boolean   @default(false)
  responseDate          DateTime?
  responseNotes         String?
  createdAt             DateTime  @default(now())

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)

  @@map("company_verifications")
}

model DocumentAnalysis {
  id                    String       @id @default(cuid())
  verificationRequestId String
  documentType          DocumentType
  fileName              String
  fileUrl               String?
  extractedText         String?
  metadataCreatedAt     DateTime?
  metadataModifiedAt    DateTime?
  authenticityScore     Float?
  flags                 String[]
  analyzedAt            DateTime     @default(now())

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)

  @@map("document_analyses")
}

model VerificationResult {
  id                    String    @id @default(cuid())
  verificationRequestId String    @unique
  overallRiskScore      Float
  riskLevel             RiskLevel
  githubScore           Float     @default(0)
  companyScore          Float     @default(0)
  documentScore         Float     @default(0)
  temporalScore         Float     @default(0)
  summary               String?
  recommendation        String?
  createdAt             DateTime  @default(now())

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)
  inconsistencyFlags  InconsistencyFlag[]
  skillVerifications  SkillVerification[]

  @@map("verification_results")
}

model InconsistencyFlag {
  id                   String       @id @default(cuid())
  verificationResultId String
  claimId              String?
  severity             FlagSeverity
  category             String
  message              String
  evidenceSources      String[]
  createdAt            DateTime     @default(now())

  verificationResult VerificationResult @relation(fields: [verificationResultId], references: [id], onDelete: Cascade)
  claim              ResumeClaim?       @relation(fields: [claimId], references: [id])

  @@map("inconsistency_flags")
}

model SkillVerification {
  id                   String      @id @default(cuid())
  verificationResultId String
  claimId              String?
  skillName            String
  status               SkillStatus
  evidenceRepos        String[]
  confidenceScore      Float       @default(0)

  verificationResult VerificationResult @relation(fields: [verificationResultId], references: [id], onDelete: Cascade)
  claim              ResumeClaim?       @relation(fields: [claimId], references: [id])

  @@map("skill_verifications")
}

model AuditLog {
  id                    String   @id @default(cuid())
  userId                String?
  verificationRequestId String?
  action                String
  details               Json?
  ipAddress             String?
  createdAt             DateTime @default(now())

  user                User?                @relation(fields: [userId], references: [id])
  verificationRequest VerificationRequest? @relation(fields: [verificationRequestId], references: [id])

  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// ─── PLACEMENT PORTAL ─────────────────────────────────────
// ═══════════════════════════════════════════════════════════

model Institution {
  id        String   @id @default(cuid())
  name      String
  domain    String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     InstitutionMember[]
  students    Student[]           @relation("InstitutionStudents")
  inviteCodes InviteCode[]
  jobBoard    JobBoardEntry[]

  @@map("institutions")
}

model InstitutionMember {
  id            String   @id @default(cuid())
  userId        String   @unique
  institutionId String
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("institution_members")
}

model InviteCode {
  id            String    @id @default(cuid())
  code          String    @unique
  institutionId String
  batchId       String?   // groups codes generated together
  batchName     String?   // user-editable label for the batch
  expiresAt     DateTime?
  usedById      String?   @unique
  createdAt     DateTime  @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  usedBy      Student?    @relation("UsedInviteCode", fields: [usedById], references: [id])

  @@index([batchId])
  @@map("invite_codes")
}


model Company {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members CompanyMember[]
  jobs    Job[]

  @@map("companies")
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String   @unique
  companyId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_members")
}

model Job {
  id            String        @id @default(cuid())
  companyId     String
  title         String
  description   String
  skills        String[]
  location      String?
  isRemote      Boolean       @default(false)
  jobType       String        // INTERNSHIP | FULL_TIME | PART_TIME | CONTRACT
  visibility    JobVisibility @default(PUBLIC)
  status        JobStatus     @default(DRAFT)
  deadline      DateTime?
  openPositions Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  boardEntries JobBoardEntry[]
  applications Application[]

  @@map("jobs")
}

model JobBoardEntry {
  id            String              @id @default(cuid())
  jobId         String
  institutionId String
  status        BoardEntryStatus    @default(APPROVED)
  initiator     BoardEntryInitiator
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([jobId, institutionId])
  @@map("job_board_entries")
}

model Application {
  id        String            @id @default(cuid())
  studentId String
  jobId     String
  status    ApplicationStatus @default(APPLIED)
  coverNote String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  disclosedClaims ApplicationClaim[]

  @@unique([studentId, jobId])
  @@map("applications")
}

model ApplicationClaim {
  applicationId String
  claimId       String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  claim       ResumeClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@id([applicationId, claimId])
  @@map("application_claims")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
